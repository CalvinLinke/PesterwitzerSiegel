# ------------------------------------------------------------------
# Admin-Zugang (geheimer Link + Passwort) zur Speisekarten-Verwaltung
# ------------------------------------------------------------------
# Der geheime Pfad-Schlüssel. Der Magic-Link lautet dann:
#   https://IHRE-DOMAIN/admin/login?key=<ADMIN_SECRET_PATH>
ADMIN_SECRET_PATH="bitte-langen-zufaelligen-wert-eintragen"

# Passwort fuer die Anmeldung auf der Adminseite
ADMIN_PASSWORD="bitte-sicheres-passwort-eintragen"

# Zufaelliges Geheimnis zum Signieren des Login-Cookies (min. 32 Zeichen)
ADMIN_SESSION_SECRET="bitte-langen-zufaelligen-wert-eintragen"

# ------------------------------------------------------------------
# Speicher der Speisekarten (Vercel Blob, KEINE Datenbank)
# ------------------------------------------------------------------
# Wird von Vercel automatisch gesetzt, sobald ein Blob-Store verbunden ist.
# Ohne diesen Wert laeuft die Seite mit den Standard-Speisekarten (Seed),
# Speichern im Admin ist dann deaktiviert.
BLOB_READ_WRITE_TOKEN=""
